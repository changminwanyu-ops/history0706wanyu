rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboard/{document} {
      // Anyone can read leaderboard scores
      allow read: if true;
      
      // Anyone can submit a score, provided it has valid fields
      allow create: if request.resource.data.name is string 
                   && request.resource.data.name.size() > 0
                   && request.resource.data.name.size() <= 30
                   && request.resource.data.timeInSeconds is number
                   && request.resource.data.attempts is number;
                   
      // No updates or deletes allowed from client side to maintain leaderboard integrity
      allow update, delete: if false;
    }
  }
}
